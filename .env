#DEVICE CONFIGURATION
DEVICE_MODEL= Garagentor Modell X
DEVICE_MANUFACTURER= Deine Firma

# MQTT-Konfiguration
MQTT_HOST=IP vom MQTT Broker zb Homeassistant
MQTT_PORT=1883
MQTT_USER=dein_benutzername
MQTT_PASSWORD=dein_passwort

# Zeitzone
TZ=Europe/Berlin

# Webserver-Port
PORT=5000

# MQTT-Themen (falls in "Hilfe anfordern" verwendet)
IMAGE_TOPIC=homeassistant/image_processing/garage_door
RESULT_TOPIC=homeassistant/binary_sensor/garage_door_state
